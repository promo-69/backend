PORT=
NODE_ENV=
SECURE_PROTOCOL=
DOMAIN=
API_HOST=

# ---------------------------------------------
# MIDDLEWARE
# ---------------------------------------------
CORS_ORIGIN=
ENABLE_CORS=
ENABLE_HELMET=
ENABLE_MORGAN=
ENABLE_DATABASE=

# ---------------------------------------------
# RATE LIMITING
# ---------------------------------------------
