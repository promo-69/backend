{
	"name": "cineflix-backend",
	"version": "1.0.0",
	"description": "API Restful by Promo69",
	"author": "promo69-team",
	"main": "build/index.js",
	"type": "module",
	"scripts": {
		"build": "cross-env vite build",
		"build:full": "yarn clean && yarn build",
		"start": "node build/index.js",
		"dev": "yarn type-check && vite-node --watch --mode development src/index.ts",
		"dev:simple": "vite-node --mode development src/index.ts",
		"dev:inspect": "tsx watch --inspect src/index.ts",
		"clean": "rimraf build",
		"clean:all": "rimraf build node_modules/.cache",
		"lint": "eslint \"src/**/*.{ts,cjs,js}\"",
		"format": "prettier --write \"src/**/*.{ts,cjs,js}\"",
		"type-check": "tsc --noEmit",
		"test": "cross-env NODE_OPTIONS=--experimental-vm-modules npx jest",
		"db:create": "node src/migrate/run-cli.js db:create",
		"db:drop": "node src/migrate/run-cli.js db:drop",
		"db:migrate": "node src/migrate/run-cli.js db:migrate",
		"db:migrate:undo": "node src/migrate/run-cli.js db:migrate:undo",
		"db:migrate:undo:all": "node src/migrate/run-cli.js db:migrate:undo:all",
		"db:seed": "node src/migrate/run-cli.js db:seed:all",
		"db:seed:undo": "node src/migrate/run-cli.js db:seed:undo:all",
		"db:generate:seed": "node src/migrate/run-cli.js seed:generate",
		"db:generate:migration": "node src/migrate/run-cli.js migration:generate",
		"db:setup": "node src/migrate/run-cli.js setup",
		"db:setup:full": "node src/migrate/run-cli.js setup:full",
		"db:reset": "node src/migrate/run-cli.js reset",
		"db:reset:full": "node src/migrate/run-cli.js reset:full",
		"docker:exec": "docker compose -f docker-compose.yml exec",
		"docker:api-exec": "yarn docker:exec api",
		"docker:db:setup": "yarn docker:api-exec yarn db:setup",
		"docker:db:setup:full": "yarn docker:api-exec yarn db:setup:full",
		"docker:db:reset": "yarn docker:api-exec yarn db:reset",
		"docker:db:migrate": "yarn docker:api-exec yarn db:migrate",
		"docker:db:migrate:undo": "yarn docker:api-exec yarn db:migrate:undo",
		"docker:db:migrate:undo:all": "yarn docker:api-exec yarn db:migrate:undo:all",
		"docker:db:seed": "yarn docker:api-exec yarn db:seed",
		"docker:db:seed:undo": "yarn docker:api-exec yarn db:seed:undo",
		"docker:db:reset:full": "yarn docker:api-exec yarn db:reset:full",
		"docker:build": "docker compose -f docker-compose.yml up -d --build",
		"docker:up": "docker compose -f docker-compose.yml up -d",
		"docker:down": "docker compose -f docker-compose.yml down",
		"docker:down:volumes": "docker compose -f docker-compose.yml down -v",
		"docker:down:hard": "docker compose -f docker-compose.yml down -v --rmi local",
		"docker:logs": "docker compose -f docker-compose.yml logs -f",
		"docker:reset": "docker compose -f docker-compose.yml down -v --rmi local && docker compose -f docker-compose.yml up -d --build",
		"docker:reset:full": "docker compose -f docker-compose.yml down -v --rmi local && docker compose -f docker-compose.yml up -d --build && yarn docker:db:reset:full --id main"
	},
	"devDependencies": {
		"@apidevtools/swagger-parser": "^12.1.0",
		"@types/bcryptjs": "^3.0.0",
		"@types/cors": "^2.8.19",
		"@types/express": "^5.0.6",
		"@types/helmet": "^4.0.0",
		"@types/jest": "^30.0.0",
		"@types/jsonwebtoken": "^9.0.10",
		"@types/morgan": "^1.9.10",
		"@types/multer": "^2.0.0",
		"@types/node": "^25.0.3",
		"@types/supertest": "^7.2.0",
		"@types/swagger-ui-express": "^4.1.8",
		"@types/yamljs": "^0.2.34",
		"@typescript-eslint/eslint-plugin": "^8.50.0",
		"@typescript-eslint/parser": "^8.50.0",
		"cross-env": "^10.1.0",
		"esbuild-plugin-tsconfig-paths": "^1.0.2",
		"eslint": "^9.39.2",
		"eslint-config-prettier": "^10.0.2",
		"jest": "^30.3.0",
		"prettier": "^3.5.2",
		"supertest": "^7.2.2",
		"ts-jest": "^29.4.6",
		"ts-node": "^10.9.2",
		"tsc-alias": "^1.8.16",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"vite": "^8.0.1",
		"vite-node": "^6.0.0"
	},
	"dependencies": {
		"@types/cookie-parser": "^1.4.10",
		"@types/nodemailer": "^7.0.4",
		"@types/sequelize": "^6.12.0",
		"bcryptjs": "^3.0.3",
		"cookie-parser": "^1.4.7",
		"cors": "^2.8.5",
		"dotenv": "^17.2.3",
		"express": "^5.2.1",
		"helmet": "^8.1.0",
		"imagekit": "^6.0.0",
		"ioredis": "^5.10.1",
		"joi": "^18.0.2",
		"jsonwebtoken": "^9.0.3",
		"mime-types": "^3.0.2",
		"morgan": "^1.10.1",
		"multer": "^2.0.2",
		"nanoid": "^5.1.7",
		"nodemailer": "^7.0.12",
		"pg": "^8.16.3",
		"sequelize": "^6.37.7",
		"sequelize-cli": "^6.6.5",
		"swagger-ui-express": "^5.0.1",
		"yamljs": "^0.3.0"
	}
}
