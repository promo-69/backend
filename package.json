{
    "name": "cineflix-backend",
    "version": "1.0.0",
    "description": "API Restful by Promo69",
    "author": "promo69-team",
    "main": "build/index.js",
    "type": "module",
    "scripts": {
        "build": "cross-env vite build",
        "build:full": "yarn clean && yarn build",
        "start": "node build/index.js",
        "dev": "yarn type-check && vite-node --watch --mode development src/index.ts",
        "dev:simple": "vite-node --mode development src/index.ts",
        "dev:inspect": "tsx watch --inspect src/index.ts",
        "clean": "rimraf build",
        "clean:all": "rimraf build node_modules/.cache",
        "lint": "eslint \"src/**/*.{ts,js}\"",
        "format": "prettier --write \"src/**/*.{ts,js}\"",
        "type-check": "tsc --noEmit",
        "test": "cross-env NODE_OPTIONS=--experimental-vm-modules npx jest"
    },
    "devDependencies": {
        "@types/bcryptjs": "^3.0.0",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/helmet": "^4.0.0",
        "@types/jest": "^30.0.0",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/morgan": "^1.9.10",
        "@types/multer": "^2.0.0",
        "@types/node": "^25.0.3",
        "@types/supertest": "^7.2.0",
        "@typescript-eslint/eslint-plugin": "^8.50.0",
        "@typescript-eslint/parser": "^8.50.0",
        "cross-env": "^10.1.0",
        "esbuild-plugin-tsconfig-paths": "^1.0.2",
        "eslint": "^9.39.2",
        "eslint-config-prettier": "^10.0.2",
        "jest": "^30.3.0",
        "nodemon": "^3.1.11",
        "prettier": "^3.5.2",
        "rimraf": "^6.1.2",
        "supertest": "^7.2.2",
        "ts-jest": "^29.4.6",
        "ts-node": "^10.9.2",
        "tsc-alias": "^1.8.16",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3",
        "vite": "^8.0.1",
        "vite-node": "^6.0.0"
    },
    "dependencies": {
        "@types/cookie-parser": "^1.4.10",
        "@types/nodemailer": "^7.0.4",
        "@types/sequelize": "^6.12.0",
        "bcryptjs": "^3.0.3",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.5",
        "dotenv": "^17.2.3",
        "express": "^5.2.1",
        "helmet": "^8.1.0",
        "joi": "^18.0.2",
        "jsonwebtoken": "^9.0.3",
        "mime-types": "^3.0.2",
        "morgan": "^1.10.1",
        "multer": "^2.0.2",
        "nanoid": "^5.1.6",
        "nodemailer": "^7.0.12",
        "pg": "^8.16.3",
        "sequelize": "^6.37.7"
    }
}
