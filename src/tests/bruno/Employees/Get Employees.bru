meta {
  name: Get Employees
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/employees
  body: none
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

script:post-response {
  const resBody = res.getBody();
  if (res.getStatus() !== 200) throw new Error(`Expected status 200 but got ${res.getStatus()}`);
  if (!resBody?.data) throw new Error('Get Employees response invalid: missing data');
  if (!Array.isArray(resBody.data) && !Array.isArray(resBody.data.rows)) throw new Error('Get Employees response invalid: data should be an array or contain rows');
}

script:pre-request {
  const baseUrl = bru.getEnvVar('baseUrl') || 'http://127.0.0.1:4000/api/v1';
  bru.setVar('baseUrl', baseUrl);
}
