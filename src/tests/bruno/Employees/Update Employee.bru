meta {
  name: Update Employee
  type: http
  seq: 4
}

patch {
  url: {{baseUrl}}/employees/{{testEmployeeId}}
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "employeeCode": "BRU-EMP-001-UPDATED",
    "firstName": "Bruno Modificado",
    "lastName": "Test Modificado",
    "phoneNumber": "+584120000000",
    "email": "bruno.mod@cineflix.com",
    "birthDate": "1990-05-15",
    "gender": 1
  }
}

script:post-response {
  if (res.getStatus() !== 200) throw new Error(`Expected status 200 but got ${res.getStatus()}`);
}

script:pre-request {
  const baseUrl = bru.getEnvVar('baseUrl') || 'http://127.0.0.1:4000/api/v1';
  bru.setVar('baseUrl', baseUrl);
}
