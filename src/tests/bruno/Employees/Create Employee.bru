meta {
  name: Create Employee
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/employees
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "documentNumber": "BRU123456",
    "firstName": "Bruno",
    "lastName": "Test",
    "employeeCode": "BRU-EMP-001",
    "jobPosition": 1,
    "startDate": "2026-04-23",
    "salaryBase": 1200.0,
    "email": "bruno.test@cineflix.com",
    "password": "SecurePass123!"
  }
}

script:post-response {
  const resBody = res.getBody();
  if (res.getStatus() !== 201) throw new Error(`Expected status 201 but got ${res.getStatus()}`);
  if (!resBody?.data?.employee?.id) throw new Error('Create Employee response invalid: missing employee.id');
  bru.setEnvVar('testEmployeeId', String(resBody.data.employee.id));
}

script:pre-request {
  const baseUrl = bru.getEnvVar('baseUrl') || 'http://127.0.0.1:4000/api/v1';
  bru.setVar('baseUrl', baseUrl);
}
