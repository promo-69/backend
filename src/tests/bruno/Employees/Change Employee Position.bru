meta {
  name: Change Employee Position
  type: http
  seq: 5
}

patch {
  url: {{baseUrl}}/employees/{{testEmployeeId}}/position
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "jobPosition": 2,
    "cinema": 1,
    "startDate": "2026-05-01",
    "salaryBase": 1400.0
  }
}

script:post-response {
  const resBody = res.getBody();
  if (res.getStatus() !== 200) throw new Error(`Expected status 200 but got ${res.getStatus()}`);
  if (!resBody?.data?.id) throw new Error('Change Employee Position response invalid: missing data.id');
}

script:pre-request {
  const baseUrl = bru.getEnvVar('baseUrl') || 'http://127.0.0.1:4000/api/v1';
  bru.setVar('baseUrl', baseUrl);
}
