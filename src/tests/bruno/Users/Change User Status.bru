meta {
  name: Change User Status (Manager)
  type: http
  seq: 5
}

patch {
  url: {{baseUrl}}/users/{{testUserId}}/status
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "status": 0
  }
}

vars:pre-request {
  testUserId: 2
}

script:pre-request {
  const baseUrl = bru.getEnvVar('baseUrl') || 'http://127.0.0.1:4000/api/v1';
  bru.setVar('baseUrl', baseUrl);
}
