meta {
  name: Get User Permissions
  type: http
  seq: 5
}

get {
  url: {{baseUrl}}/users/{{testUserId}}/permissions
  body: none
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

vars:pre-request {
  testUserId: 1
}

script:pre-request {
  const baseUrl = bru.getEnvVar('baseUrl') || 'http://127.0.0.1:4000/api/v1';
  bru.setVar('baseUrl', baseUrl);
}
