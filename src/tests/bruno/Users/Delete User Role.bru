meta {
  name: Delete User Role
  type: http
  seq: 5
}

delete {
  url: {{baseUrl}}/users/{{testUserId}}/role
  body: none
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

vars:pre-request {
  testUserId: 2
}

script:pre-request {
  const baseUrl = bru.getEnvVar('baseUrl') || 'http://127.0.0.1:4000/api/v1';
  bru.setVar('baseUrl', baseUrl);
}
