meta {
  name: Assign User Role
  type: http
  seq: 5
}

post {
  url: {{baseUrl}}/users/{{testUserId}}/role
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "roleId": {{testRoleId}}
  }
}

vars:pre-request {
  testUserId: 1
  testRoleId: 4
}

script:pre-request {
  const baseUrl = bru.getEnvVar('baseUrl') || 'http://127.0.0.1:4000/api/v1';
  bru.setVar('baseUrl', baseUrl);
}
