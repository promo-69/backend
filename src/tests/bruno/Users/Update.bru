meta {
  name: Update Profile
  type: http
  seq: 4
}

patch {
  url: {{baseUrl}}/users/profile
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "phoneNumber": "9876543210",
    "firstName": "Bruno",
    "lastName": "Updated",
    "personalEmail": "bruno.updated@example.com"
  }
}
