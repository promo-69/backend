meta {
  name: Delete Movie
  type: http
  seq: 11
}

delete {
  url: {{baseUrl}}/admin/movies/{{movieId}}
  body: none
  auth: bearer
}

auth:bearer {
  token: AT
}

script:pre-request {
  const baseUrl = bru.getEnvVar('baseUrl') || 'http://127.0.0.1:4000/api/v1';
  const movieId = bru.getEnvVar('testMovieId') || '1';
  bru.setVar('baseUrl', baseUrl);
  bru.setVar('movieId', movieId);
}
