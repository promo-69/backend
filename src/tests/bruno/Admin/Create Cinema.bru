meta {
  name: Create Cinema
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/admin/cinemas
  body: json
  auth: bearer
}

body:json {
  {
    "name": "Test Cinema Bruno",
    "address": "123 Test Ave",
    "phone": "+1234567890",
    "opening_time": "09:00:00",
    "closing_time": "23:00:00",
    "status": 1
  }
}

auth:bearer {
  token: AT
}

script:post-response {
  const resBody = res.getBody();
  if (res.getStatus() === 201 && resBody && resBody.data && resBody.data.id) {
    bru.setEnvVar('testCinemaId', resBody.data.id);
  }
}

script:pre-request {
  const baseUrl = bru.getEnvVar('baseUrl') || 'http://127.0.0.1:4000/api/v1';
  bru.setVar('baseUrl', baseUrl);
}