meta {
  name: Update Cinema
  type: http
  seq: 4
}

put {
  url: {{baseUrl}}/admin/cinemas/{{cinemaId}}
  body: json
  auth: bearer
}

body:json {
  {
    "name": "Test Cinema Bruno Updated",
    "address": "456 Updated Ave"
  }
}

auth:bearer {
  token: AT
}

script:pre-request {
  const baseUrl = bru.getEnvVar('baseUrl') || 'http://127.0.0.1:4000/api/v1';
  const cinemaId = bru.getEnvVar('testCinemaId') || '1';
  bru.setVar('baseUrl', baseUrl);
  bru.setVar('cinemaId', cinemaId);
}
