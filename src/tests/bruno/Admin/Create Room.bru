meta {
  name: Create Room
  type: http
  seq: 12
}

post {
  url: {{baseUrl}}/admin/rooms
  body: json
  auth: bearer
}

body:json {
  {
    "cinema": 1,
    "name": "Test Room Bruno",
    "grid_rows": 8,
    "grid_columns": 12,
    "total_capacity": 96,
    "status": 1
  }
}

auth:bearer {
  token: AT
}

script:post-response {
  const resBody = res.getBody();
  if (res.getStatus() === 201 && resBody && resBody.data && resBody.data.id) {
    bru.setEnvVar('testRoomId', resBody.data.id);
  }
}

script:pre-request {
  const baseUrl = bru.getEnvVar('baseUrl') || 'http://127.0.0.1:4000/api/v1';
  bru.setVar('baseUrl', baseUrl);
}