meta {
  name: Delete Room Projection Type
  type: http
  seq: 18
}

delete {
  url: {{baseUrl}}/admin/rooms/{{roomId}}/projection-types/{{projectionTypeId}}
  body: none
  auth: bearer
}

auth:bearer {
  token: AT
}

script:pre-request {
  const baseUrl = bru.getEnvVar('baseUrl') || 'http://127.0.0.1:4000/api/v1';
  const roomId = bru.getEnvVar('testRoomId') || '1';
  const projectionTypeId = bru.getEnvVar('testRoomProjectionTypeId') || '1';
  bru.setVar('baseUrl', baseUrl);
  bru.setVar('roomId', roomId);
  bru.setVar('projectionTypeId', projectionTypeId);
}
