meta {
  name: Create Room Projection Type
  type: http
  seq: 17
}

post {
  url: {{baseUrl}}/admin/rooms/{{roomId}}/projection-types
  body: json
  auth: bearer
}

body:json {
  {
    "projection_type": 1
  }
}

auth:bearer {
  token: AT
}

script:post-response {
  const resBody = res.getBody();
  if (res.getStatus() === 201 && resBody && resBody.data && resBody.data.id) {
    bru.setEnvVar('testRoomProjectionTypeId', resBody.data.id);
  }
}

script:pre-request {
  const baseUrl = bru.getEnvVar('baseUrl') || 'http://127.0.0.1:4000/api/v1';
  const roomId = bru.getEnvVar('testRoomId') || '1';
  bru.setVar('baseUrl', baseUrl);
  bru.setVar('roomId', roomId);
}
