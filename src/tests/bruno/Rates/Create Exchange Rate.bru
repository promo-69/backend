meta {
  name: Create Exchange Rate
  type: http
  seq: 5
}

post {
  url: {{baseUrl}}/exchange-rates
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "currency": {{testCurrencyId}},
    "rate": 1.25
  }
}

vars:pre-request {
  testCurrencyId: 2
}

script:pre-request {
  const baseUrl = bru.getEnvVar('baseUrl') || 'http://127.0.0.1:4000/api/v1';
  bru.setVar('baseUrl', baseUrl);
}

script:post-response {
  const resBody = res.getBody();
  if (res.getStatus() === 201 && resBody && resBody.data && resBody.data.id) {
    bru.setEnvVar('testExchangeRateId', resBody.data.id);
  }
}
