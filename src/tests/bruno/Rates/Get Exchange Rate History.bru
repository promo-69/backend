meta {
  name: Get Exchange Rate History
  type: http
  seq: 8
}

get {
  url: {{baseUrl}}/rates/exchange-rates/currency/{{testCurrencyId}}/history?startDate=2025-01-01T00:00:00Z&endDate=2030-01-01T00:00:00Z
  body: none
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

vars:pre-request {
  testCurrencyId: 3
}

script:pre-request {
  const baseUrl = bru.getEnvVar('baseUrl') || 'http://127.0.0.1:4000/api/v1';
  bru.setVar('baseUrl', baseUrl);
}
