meta {
  name: Create Currency
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/rates/currencies
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "code": "{{testCurrencyCode}}",
    "description": "Bruno test currency",
    "symbol": "B",
    "is_base_currency": false
  }
}

vars:pre-request {
  testCurrencyCode: 1234
}

script:pre-request {
  const baseUrl = bru.getEnvVar('baseUrl') || 'http://127.0.0.1:4000/api/v1';
  bru.setVar('baseUrl', baseUrl);
  const code = `BRU123`;
  bru.setVar('testCurrencyCode', code);
}

script:post-response {
  if (res.getStatus() !== 201) throw new Error(`Expected status 201 but got ${res.getStatus()}`);
  const resBody = res.getBody();
  if (resBody && resBody.data && resBody.data.id) {
    bru.setEnvVar('testCurrencyId', resBody.data.id);
  }
}
