meta {
  name: Update Currency
  type: http
  seq: 4
}

put {
  url: {{baseUrl}}/rates/currencies/{{testCurrencyId}}
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "description": "Bruno updated test currency",
    "symbol": "BU"
  }
}

vars:pre-request {
  testCurrencyId: 3
}

script:pre-request {
  const baseUrl = bru.getEnvVar('baseUrl') || 'http://127.0.0.1:4000/api/v1';
  bru.setVar('baseUrl', baseUrl);
}

script:post-response {
  if (res.getStatus() !== 200) throw new Error(`Expected status 200 but got ${res.getStatus()}`);
}
