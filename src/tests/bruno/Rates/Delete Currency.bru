meta {
  name: Delete Currency
  type: http
  seq: 10
}

delete {
  url: {{baseUrl}}/rates/currencies/{{testCurrencyId}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

vars:pre-request {
  testCurrencyId: 3
}

script:pre-request {
  const baseUrl = bru.getEnvVar('baseUrl') || 'http://127.0.0.1:4000/api/v1';
  bru.setVar('baseUrl', baseUrl);
}
