meta {
  name: Login
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/auth/login
  body: json
  auth: none
}

body:json {
  {
    "username": "{{username}}",
    "password": "{{password}}"
  }
}

vars:pre-request {
  username: alirio2
}

script:post-response {
  const data = res.getBody();
  if (data.data && data.data.accessToken) {
    bru.setEnvVar("accessToken", data.data.accessToken);
  }
  if (data.data && data.data.refreshToken) {
    bru.setEnvVar("refreshToken", data.data.refreshToken);
  }
}
