meta {
  name: Login
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/auth/login
  body: json
  auth: none
}

body:json {
    {
        "email": "",
        "password": ""
    }
}

script:post-response {
    // Obtener los datos de la respuesta (Response)
    const resBody = res.getBody();
    const resStatus = res.getStatus();

    // Solo guardamos variables si la petición fue exitosa (HTTP 2xx)
    if (200 <= resStatus && resStatus <= 299 && resBody && resBody.data) {
        // Guardar tokens de la respuesta
        if (resBody.data?.tokens.accessToken)
            bru.setEnvVar("accessToken", resBody.data.tokens.accessToken);

        if (resBody.data?.tokens.refreshToken)
            bru.setEnvVar("refreshToken", resBody.data.tokens.refreshToken);
    }
}
