meta {
    name: Login
    type: https
    seq: 1
}

post {
    url: {{baseUrl}}/auth/login
    body: json
    auth: none
}

body:json {
    {
        "email": "{{loginEmail}}",
        "password": "{{loginPassword}}"
    }
}

script:pre-request {
    // 1. Prioridad: el último correo registrado (email), luego el de prueba (testEmail), o un fallback.
    const targetEmail = bru.getEnvVar("loginEmail") ||  bru.getEnvVar("email") || bru.getEnvVar("testEmail") || "fallback@example.example";
    const targetPassword = bru.getEnvVar("loginPassword") || bru.getEnvVar("password") || bru.getEnvVar("testPassword") || "fallback12345678*";

    // 2. Asignamos a variables temporales con nombres únicos para el JSON
    bru.setVar("loginEmail", targetEmail);
    bru.setVar("loginPassword", targetPassword);
}

script:post-response {
    const resBody = res.getBody();
    const resStatus = res.getStatus();

    // Solo guardamos los tokens si las credenciales fueron correctas (HTTP 2xx)
    if (200 <= resStatus && resStatus <= 299 && resBody && resBody.data) {
        
        if (resBody.data.accessToken)
            bru.setEnvVar("accessToken", resBody.data.accessToken);

        if (resBody.data.refreshToken)
            bru.setEnvVar("refreshToken", resBody.data.refreshToken);
    }
}