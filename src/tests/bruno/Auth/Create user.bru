meta {
  name: Create a customer account
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/auth/signup
  body: json
  auth: none
}

body:json {
    {
        "user": {
            "username": "testuserda",
            "password": "tesT*1234"
        },
        "person": {
            "documentNumber": "v-12315600",
            "firstName": "test firstname",
            "lastName": "test lastname",
            "gender": 1,
            "birthDate": "2001-01-01",
            "email": "test.te_st@test.test",
            "phoneNumber": "12345678900"
        }
    }
}

script:post-response {
  const data = res.getBody();
  if (data.data && data.data.accessToken) {
    bru.setEnvVar("accessToken", data.data.accessToken);
  }
  if (data.data && data.data.refreshToken) {
    bru.setEnvVar("refreshToken", data.data.refreshToken);
  }
}
