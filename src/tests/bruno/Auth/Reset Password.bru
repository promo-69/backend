meta {
  name: Reset Password
  type: http
  seq: 8
}

post {
  url: {{baseUrl}}/auth/reset-password/{{userType}}
  body: json
  auth: none
}

body:json {
  {
    "email": "aliriofreytez1@gmail.com",
    "resetToken": "{{resetToken}}",
    "newPassword": "NewPassword123!"
  }
}

vars:pre-request {
  userType: client
  resetToken: QpaQebtTC6uyFoUeVkHrSx4aPcqwsMHeiIKLVT7QaHM1zQLzz4VJTqyJKGTOyBz4
}

script:post-response {
  if (res.status === 200) {
    bru.deleteEnvVar("resetToken");
  }
}
