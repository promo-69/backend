meta {
  name: Reset Password
  type: http
  seq: 8
}

post {
  url: {{baseUrl}}/auth/reset-password
  body: json
  auth: none
}

body:json {
  {
    "email": "user@example.com",
    "resetToken": "{{resetToken}}",
    "newPassword": "NewPassword123!"
  }
}

script:post-response {
  if (res.status === 200) {
    bru.deleteEnvVar("resetToken");
  }
}
