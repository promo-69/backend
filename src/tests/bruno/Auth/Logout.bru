meta {
  name: Logout
  type: http
  seq: 7
}

post {
  url: {{baseUrl}}/auth/logout
  body: none
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

script:post-response {
    // Obtener los datos de la respuesta (Response)
    const resBody = res.getBody();
    const resStatus = res.getStatus();

    // Solo eliminamos variables si la petición fue exitosa (HTTP 2xx)
    if (200 <= resStatus && resStatus <= 299 && resBody && resBody.data) {
        if (resBody.data.accessToken)
            bru.setEnvVar("accessToken", "");

        if (resBody.data.refreshToken)
            bru.setEnvVar("refreshToken", "");
    }
}
