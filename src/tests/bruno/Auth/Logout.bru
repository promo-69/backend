meta {
  name: Logout
  type: http
  seq: 5
}

post {
  url: {{baseUrl}}/auth/logout
  body: none
  auth: bearer
}

headers {
  x-client-channel: mobile
}

auth:bearer {
  token: {{accessToken}}
}

script:post-response {
  if (res.status === 200) {
    bru.deleteEnvVar("accessToken");
    bru.deleteEnvVar("refreshToken");
  }
}
