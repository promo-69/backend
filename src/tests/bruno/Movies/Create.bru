meta {
  name: Create Movie
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/movies
  body: json
  auth: bearer
}

body:json {
  {
    "title": "Test Movie Bruno",
    "duration_minutes": 120,
    "age_classification": 1,
    "lifecycle_state": 2,
    "synopsis": "A movie created during Bruno test execution.",
    "trailer_url": "https://example.com/trailer.mp4",
    "release_date": "2026-04-09",
    "genres": [1]
  }
}

auth:bearer {
  token: {{accessToken}}
}

script:post-response {
  const resBody = res.getBody();
  if (res.getStatus() === 201 && resBody && resBody.data && resBody.data.movie_id) {
    bru.setEnvVar('testMovieId', resBody.data.movie_id);
  }
}

script:pre-request {
  const baseUrl = bru.getEnvVar('baseUrl') || 'http://127.0.0.1:4000/api/v1';
  bru.setVar('baseUrl', baseUrl);
}