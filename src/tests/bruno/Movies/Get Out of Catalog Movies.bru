meta {
  name: Get Out of Catalog Movies (lifecycle=5) - Admin only
  type: http
  seq: 5
}

get {
  url: {{baseUrl}}/movies?lifecycle_state=5
  body: none
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

params:query {
  page: 1
  limit: 10
}

docs {
  Obtiene las películas con lifecycle_state = 5 (Fuera de Cartelera).
  Requiere permisos de administrador (CRUD:READ:MOVIES).
  El filtro se aplica mediante el parámetro `lifecycle_state`.
  No accesible para clientes normales.
}
