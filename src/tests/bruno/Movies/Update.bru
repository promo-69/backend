meta {
  name: Update Movie
  type: http
  seq: 5
}

patch {
  url: {{baseUrl}}/movies/{{testMovieId}}
  body: multipartForm
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:multipart-form {
  synopsis: Updated Bruno movie synopsis.
  lifecycleState: 3
  ~poster:
  ~banner:
}

vars:pre-request {
  testMovieId: 2
}

script:pre-request {
  const baseUrl = bru.getEnvVar('baseUrl') || 'http://127.0.0.1:4000/api/v1';
  bru.setVar('baseUrl', baseUrl);
}
