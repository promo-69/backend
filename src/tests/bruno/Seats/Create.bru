meta {
  name: Create Seats
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/rooms/{{testRoomId}}/seats
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  [
    { "row": 1, "column": 1, "seatCondition": 1 },
    { "row": 1, "column": 2, "seatCondition": 1 }
  ]
}

script:pre-request {
  const baseUrl = bru.getEnvVar('baseUrl') || 'http://127.0.0.1:4000/api/v1';
  bru.setVar('baseUrl', baseUrl);
}
