meta {
  name: Update Seat
  type: http
  seq: 3
}

patch {
  url: {{baseUrl}}/seats/{{testSeatId}}
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "seatCondition": 2,
    "seatCategory": 1
  }
}

script:pre-request {
  const baseUrl = bru.getEnvVar('baseUrl') || 'http://127.0.0.1:4000/api/v1';
  bru.setVar('baseUrl', baseUrl);
}
