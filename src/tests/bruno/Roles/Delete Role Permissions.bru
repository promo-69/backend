meta {
  name: Delete Role Permissions
  type: http
  seq: 6
}

delete {
  url: {{baseUrl}}/roles/{{testRoleId}}/permissions
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "permissions": [1]
  }
}

script:pre-request {
  const baseUrl = bru.getEnvVar('baseUrl') || 'http://127.0.0.1:4000/api/v1';
  bru.setVar('baseUrl', baseUrl);
}
