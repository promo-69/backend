meta {
  name: Update Role
  type: http
  seq: 4
}

patch {
  url: {{baseUrl}}/roles/{{testRoleId}}
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "name": "Bruno Role Updated",
    "description": "Rol de prueba actualizado"
  }
}

script:pre-request {
  const baseUrl = bru.getEnvVar('baseUrl') || 'http://127.0.0.1:4000/api/v1';
  bru.setVar('baseUrl', baseUrl);
}
