meta {
  name: Checkout Order
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/orders/checkout
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "queue_id": "{{queueId}}",
    "concessions": [
      { "line_type": 1, "product": 1, "quantity": 1 },
      { "line_type": 1, "product": 2, "quantity": 3 }
    ]
  }
}

vars:pre-request {
  queueId: f921135f-7315-4a03-a110-2778cb14cdab
}
