meta {
  name: Quote Order
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/orders/quote
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "cinema": 1
  }
}

script:post-response {
  if (res.status === 200) {
    const data = res.getBody();
    if (data.data && data.data.queue_id) {
      bru.setEnvVar("queueId", data.data.queue_id);
    }
  }
}
