meta {
  name: Get Exchange Rate By Id
  type: http
  seq: 7
}

get {
  url: {{baseUrl}}/exchange-rates/{{testExchangeRateId}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

vars:pre-request {
  testExchangeRateId: 1
}

script:pre-request {
  const baseUrl = bru.getEnvVar('baseUrl') || 'http://127.0.0.1:4000/api/v1';
  bru.setVar('baseUrl', baseUrl);
}
