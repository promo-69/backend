meta {
  name: Update Event
  type: http
  seq: 13
}

patch {
  url: {{baseUrl}}/special-events/{{eventId}}
  body: multipartForm
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:multipart-form {
  title: Final Champions League 2026 – Edición Especial
  description: Descripción actualizada.
  lifecycleState: 4
}

vars:pre-request {
  eventId: 1
}

script:pre-request {
  const baseUrl = bru.getEnvVar('baseUrl') || 'http://127.0.0.1:4000/api/v1';
  bru.setVar('baseUrl', baseUrl);
}
