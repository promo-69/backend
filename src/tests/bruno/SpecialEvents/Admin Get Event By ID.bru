meta {
  name: Admin Get Event By ID
  type: http
  seq: 8
}

get {
  url: {{baseUrl}}/special-events/admin/{{eventId}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

vars:pre-request {
  eventId: 1
}

script:pre-request {
  const baseUrl = bru.getEnvVar('baseUrl') || 'http://127.0.0.1:4000/api/v1';
  bru.setVar('baseUrl', baseUrl);
}
