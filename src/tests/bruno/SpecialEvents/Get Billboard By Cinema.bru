meta {
  name: Get Billboard By Cinema
  type: http
  seq: 5
}

get {
  url: {{baseUrl}}/special-events/billboard?cinemaId={{cinemaId}}
  body: none
  auth: none
}

vars:pre-request {
  cinemaId: 1
}

script:pre-request {
  const baseUrl = bru.getEnvVar('baseUrl') || 'http://127.0.0.1:4000/api/v1';
  bru.setVar('baseUrl', baseUrl);
}
