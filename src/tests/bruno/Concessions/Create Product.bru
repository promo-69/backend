meta {
  name: Create Product
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/concessions/products
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "name": "Test Product Bruno",
    "sku": "TST-PRD-001",
    "productCategory": 1,
    "currencyId": 1,
    "price": 5.50,
    "earnedLoyaltyPoints": 5
  }
}

script:post-response {
  const resBody = res.getBody();
  if (res.getStatus() === 201 && resBody && resBody.data && resBody.data.id) {
    bru.setEnvVar('testProductId', resBody.data.id);
  }
}

script:pre-request {
  const baseUrl = bru.getEnvVar('baseUrl') || 'http://127.0.0.1:4000/api/v1';
  bru.setVar('baseUrl', baseUrl);
}
