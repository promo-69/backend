meta {
  name: Create Category
  type: http
  seq: 11
}

post {
  url: {{baseUrl}}/concessions/categories
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "name": "Test Category Bruno",
    "description": "A category created during Bruno test execution."
  }
}

script:post-response {
  const resBody = res.getBody();
  if (res.getStatus() === 201 && resBody && resBody.data && resBody.data.id) {
    bru.setEnvVar('testCategoryId', resBody.data.id);
  }
}

script:pre-request {
  const baseUrl = bru.getEnvVar('baseUrl') || 'http://127.0.0.1:4000/api/v1';
  bru.setVar('baseUrl', baseUrl);
}
