meta {
  name: Add Combo Items
  type: http
  seq: 19
}

post {
  url: {{baseUrl}}/concessions/combos/{{testComboId}}/items
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "items": [
      { "productId": 1, "quantity": 1 }
    ]
  }
}

script:pre-request {
  const baseUrl = bru.getEnvVar('baseUrl') || 'http://127.0.0.1:4000/api/v1';
  bru.setVar('baseUrl', baseUrl);
}
