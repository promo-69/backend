meta {
  name: Update Product
  type: http
  seq: 4
}

put {
  url: {{baseUrl}}/concessions/products/{{testProductId}}
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "name": "Test Product Bruno Updated",
    "price": 6.00,
    "currencyId": 1
  }
}

script:pre-request {
  const baseUrl = bru.getEnvVar('baseUrl') || 'http://127.0.0.1:4000/api/v1';
  bru.setVar('baseUrl', baseUrl);
}
