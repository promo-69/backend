meta {
  name: Update Combo
  type: http
  seq: 8
}

put {
  url: {{baseUrl}}/concessions/combos/{{testComboId}}
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "name": "Test Combo Bruno Updated",
    "price": 16.50,
    "currencyId": 1,
    "products": [
      { "productId": {{testProductId}}, "quantity": 3 }
    ]
  }
}

script:pre-request {
  const baseUrl = bru.getEnvVar('baseUrl') || 'http://127.0.0.1:4000/api/v1';
  bru.setVar('baseUrl', baseUrl);
}
