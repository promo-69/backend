meta {
  name: Get Available Combos
  type: http
  seq: 14
}

get {
  url: {{baseUrl}}/concessions/combos/available?cinemaId=1
  body: none
  auth: bearer
}

query {
  cinemaId: 1
}

auth:bearer {
  token: {{accessToken}}
}

script:pre-request {
  const baseUrl = bru.getEnvVar('baseUrl') || 'http://127.0.0.1:4000/api/v1';
  bru.setVar('baseUrl', baseUrl);
}
