meta {
  name: Create Product
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/confiteria/products
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "name": "Palomitas grandes",
    "sku": "POP-LG-001",
    "productCategory": 1,
    "currencyId": 1,
    "price": 5.50,
    "earnedLoyaltyPoints": 5
  }
}

script:post-response {
  const resBody = res.getBody();
  if (res.getStatus() === 201 && resBody?.data?.id) {
    bru.setEnvVar("productId", resBody.data.id);
  }
}
