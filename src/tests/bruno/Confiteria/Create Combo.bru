meta {
  name: Create Combo
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/confiteria/combos
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "name": "Combo Familiar",
    "sku": "CMB-FAM-001",
    "description": "2 palomitas + 2 refrescos",
    "currencyId": 1,
    "price": 15.00,
    "products": [
      { "productId": 1, "quantity": 2 },
      { "productId": 2, "quantity": 2 }
    ]
  }
}
