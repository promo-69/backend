meta {
  name: Create PriceModifiers
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/price-modifiers
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "description": "Descuento martes para boletería",
    "modifierScope": 1,
    "operationType": 2,
    "isPercentage": true,
    "value": 15,
    "audienceCategory": 1,
    "weekDay": 3,
    "seatCategory": 2,
    "projectionType": 1
  }
}

script:pre-request {
  const baseUrl = bru.getEnvVar('baseUrl') || 'http://127.0.0.1:4000/api/v1';
  bru.setVar('baseUrl', baseUrl);
}

script:post-response {
  const resBody = res.getBody();
  if (res.getStatus() === 201 && resBody && resBody.data && resBody.data.id) {
    bru.setEnvVar('testPriceModifierId', resBody.data.id);
  }
}
