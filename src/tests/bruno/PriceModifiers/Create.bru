meta {
  name: Create PriceModifiers
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/price-modifiers
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "description": "Promoción martes",
    "modifierScope": 1,
    "operationType": 2,
    "isPercentage": true,
    "value": 20,
    "weekDay": 3,
    "cinema": 1,
    "startDate": "2026-06-01",
    "endDate": "2026-06-30",
    "startTime": "09:00:00",
    "endTime": "23:00:00",
    "currency": null,
    "targetCurrency": null,
    "targetCurrencyCondition": false
  }
}
