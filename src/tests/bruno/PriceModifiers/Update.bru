meta {
  name: Update PriceModifiers
  type: http
  seq: 4
}

put {
  url: {{baseUrl}}/price-modifiers/{{testPriceModifierId}}
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "description": "Descuento martes actualizado",
    "value": 12,
    "isPercentage": true,
    "operationType": 2
  }
}

script:pre-request {
  const baseUrl = bru.getEnvVar('baseUrl') || 'http://127.0.0.1:4000/api/v1';
  bru.setVar('baseUrl', baseUrl);
}
