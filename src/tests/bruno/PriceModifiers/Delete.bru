meta {
  name: Delete PriceModifiers
  type: http
  seq: 5
}

delete {
  url: {{baseUrl}}/price-modifiers/{{testPriceModifierId}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

script:pre-request {
  const baseUrl = bru.getEnvVar('baseUrl') || 'http://127.0.0.1:4000/api/v1';
  bru.setVar('baseUrl', baseUrl);
}
