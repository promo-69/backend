meta {
  name: Configure Seat Grid
  type: http
  seq: 1
}

put {
  url: {{baseUrl}}/rooms/{{testRoomId}}/seat-grid
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "gridRows": 10,
    "gridColumns": 15
  }
}

vars:pre-request {
  testRoomId: 1
}

script:pre-request {
  const baseUrl = bru.getEnvVar('baseUrl') || 'http://127.0.0.1:4000/api/v1';
  bru.setVar('baseUrl', baseUrl);
}
