meta {
  name: Get All Projection Types (catalog)
  type: http
  seq: 9
}

get {
  url: {{baseUrl}}/catalogs/projection-types
  body: none
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

script:pre-request {
  const baseUrl = bru.getEnvVar('baseUrl') || 'http://127.0.0.1:4000/api/v1';
  bru.setVar('baseUrl', baseUrl);
}
