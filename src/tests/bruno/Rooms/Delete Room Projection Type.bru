meta {
  name: Delete Room Projection Type
  type: http
  seq: 8
}

delete {
  url: {{baseUrl}}/rooms/{{testRoomId}}/projection-types/{{testRoomProjectionTypeId}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

script:pre-request {
  const baseUrl = bru.getEnvVar('baseUrl') || 'http://127.0.0.1:4000/api/v1';
  bru.setVar('baseUrl', baseUrl);
}