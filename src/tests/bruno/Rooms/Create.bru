meta {
  name: Create Room
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/cinemas/{{testCinemaId}}/rooms
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "name": "Test Room Bruno",
    "projectionTypes": [1],
    "gridRows": 8,
    "gridColumns": 12,
    "totalCapacity": 96
  }
}

vars:pre-request {
  testCinemaId: 1
}

script:pre-request {
  const baseUrl = bru.getEnvVar('baseUrl') || 'http://127.0.0.1:4000/api/v1';
  bru.setVar('baseUrl', baseUrl);
}

script:post-response {
  const resBody = res.getBody();
  if (res.getStatus() === 201 && resBody && resBody.data && resBody.data.room_id) {
    bru.setEnvVar('testRoomId', resBody.data.room_id);
  }
}
