meta {
  name: Get Permission By Id
  type: http
  seq: 3
}

get {
  url: {{baseUrl}}/permissions/{{testPermissionId}}
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

script:pre-request {
  const baseUrl = bru.getEnvVar('baseUrl') || 'http://127.0.0.1:4000/api/v1';
  bru.setVar('baseUrl', baseUrl);
}
