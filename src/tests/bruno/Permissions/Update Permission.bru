meta {
  name: Update Permission
  type: http
  seq: 4
}

patch {
  url: {{baseUrl}}/permissions/{{testPermissionId}}
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "permission_type": 3
  }
}

script:pre-request {
  const baseUrl = bru.getEnvVar('baseUrl') || 'http://127.0.0.1:4000/api/v1';
  bru.setVar('baseUrl', baseUrl);
}
