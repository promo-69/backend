meta {
  name: Register Inventory Movements
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/inventory/{{testInventoryId}}/movements
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  [
    { "operationType": 1, "quantity": 100, "remarks": "Weekly replenishment", "unit_cost": 5.50 }
  ]
}

script:pre-request {
  const baseUrl = bru.getEnvVar('baseUrl') || 'http://127.0.0.1:4000/api/v1';
  bru.setVar('baseUrl', baseUrl);
  if (!bru.getEnvVar('testInventoryId')) {
    throw new Error('testInventoryId no está definido. Ejecuta primero la creación de inventario.');
  }
}
