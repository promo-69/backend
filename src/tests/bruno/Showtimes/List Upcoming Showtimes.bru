meta {
  name: Listar Funciones Futuras
  type: http
  seq: 3
}

get {
  url: {{baseUrl}}/showtimes
  body: none
  auth: none
}

script:post-response {
  const resBody = res.getBody();
  if (res.getStatus() === 200 && resBody?.data?.rows?.length > 0) {
    bru.setEnvVar("showtimeId", resBody.data.rows[0].id);
  }
}

docs {
  Lista funciones futuras (sin filtros).
  Guarda automáticamente showtimeId para otras pruebas.
}
