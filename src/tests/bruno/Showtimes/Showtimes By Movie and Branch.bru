meta {
  name: Funciones de Película en Sucursal (Pública)
  type: http
  seq: 12
}

get {
  url: {{baseUrl}}/cinemas/{{testCinemaId}}/showtimes/movies/{{testMovieId}}
  body: none
  auth: none
}

vars:pre-request {
  testCinemaId: 1
  testMovieId: 2
}

script:post-response {
  const resBody = res.getBody();
  if (res.getStatus() === 200 && resBody?.data?.rows?.length > 0) {
    bru.setEnvVar('testShowtimeId', resBody.data.rows[0].id);
    bru.setEnvVar('testBookingId', resBody.data.rows[0].booking.id);
  }
}

docs {
  Endpoint público — no requiere token.
  Devuelve las funciones futuras de una película en una sucursal,
  con total_seats y available_seats por función.
  Útil para el paso "Elige tu función" del flujo de compra.
  Guarda automáticamente testShowtimeId y testBookingId para los pasos siguientes.
}
