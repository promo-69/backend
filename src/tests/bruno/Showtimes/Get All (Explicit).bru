meta {
  name: Get All Showtimes (Explicit)
  type: http
  seq: 6
}

get {
  url: {{baseUrl}}/cinemas/{{testCinemaId}}/showtimes
  body: none
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

vars:pre-request {
  testCinemaId: 1
}

script:pre-request {
  const baseUrl = bru.getEnvVar('baseUrl') || 'https://backend-jog6.onrender.com/api/v1/test';
  bru.setVar('baseUrl', baseUrl);
}
