meta {
  name: Create Showtime (Implicit)
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/showtimes
  body: json
  auth: bearer
}

auth:bearer {
  token: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..ANrWhMY7Dt9qH33PUZrVvaLXm1Q3lQG_vFOpgQRs7ng
}

body:json {
  {
    "roomId": 4,
    "movieId": 12,
    "projectionTypeId": 2,
    "startTime": "2026-06-15T18:00:00Z",
    "end_time": "2026-06-15T20:15:00Z",
    "currencyId": 2,
    "price": "5.00",
    "earned_loyalty_points": 10,
    "cinema": 8
  }
}

script:pre-request {
  const baseUrl = bru.getEnvVar('baseUrl') || 'https://backend-jog6.onrender.com/api/v1/test';
  bru.setVar('baseUrl', baseUrl);
}

script:post-response {
  const resBody = res.getBody();
  if (res.getStatus() === 201 && resBody && resBody.data && resBody.data.showtime_id) {
    bru.setEnvVar('testShowtimeId', resBody.data.showtime_id);
    bru.setEnvVar('testBookingId', resBody.data.booking_id);
  }
}
