meta {
  name: Listar películas por estado de ciclo de vida
  type: http
  seq: 19
}

get {
  url: {{baseUrl}}/showtimes/admin/movies?lifecycle=3
  body: none
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

docs {
  Filtra las películas en el backoffice por su estado en el ciclo de vida:
  lifecycle=1: Próximamente (COMING_SOON)
  lifecycle=2: Estreno Inminente / En Cartelera (PREMIERE)
  lifecycle=3: En Cartelera Activa (REGULAR)
  lifecycle=4: Últimos Días (LAST_DAYS)
  lifecycle=5: Fuera de Cartelera (OFF)
}
