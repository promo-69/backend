meta {
  name: Create Showtime
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/showtimes
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "movieId": {{testMovieId}},
    "roomId": {{testRoomId}},
    "projectionTypeId": 1,
    "startTime": "2026-06-01T18:00:00Z",
    "currencyId": 1,
    "price": 12.50,
    "earnedLoyaltyPoints": 10
  }
}

script:post-response {
  const resBody = res.getBody();
  if (res.getStatus() === 201 && resBody && resBody.data && resBody.data.id) {
    bru.setEnvVar('testShowtimeId', resBody.data.id);
  }
}

script:pre-request {
  const baseUrl = bru.getEnvVar('baseUrl') || 'http://127.0.0.1:4000/api/v1';
  bru.setVar('baseUrl', baseUrl);
}
