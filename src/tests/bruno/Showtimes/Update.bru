meta {
  name: Update Showtime
  type: http
  seq: 4
}

patch {
  url: {{baseUrl}}/showtimes/{{testShowtimeId}}
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "price": "6.00",
    "earned_loyalty_points": 15
  }
}

vars:pre-request {
  testShowtimeId: 1
}

script:pre-request {
  const baseUrl = bru.getEnvVar('baseUrl') || 'https://backend-jog6.onrender.com/api/v1/test';
  bru.setVar('baseUrl', baseUrl);
}
