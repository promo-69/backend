meta {
  name: Update Showtime
  type: http
  seq: 4
}

put {
  url: {{baseUrl}}/showtimes/{{testShowtimeId}}
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "startTime": "2026-06-01T20:00:00Z",
    "price": 14.00,
    "currencyId": 1
  }
}

script:pre-request {
  const baseUrl = bru.getEnvVar('baseUrl') || 'http://127.0.0.1:4000/api/v1';
  bru.setVar('baseUrl', baseUrl);
}
