meta {
  name: Create Showtime (via cinema)
  type: http
  seq: 10
}

post {
  url: {{baseUrl}}/cinemas/{{cinemaId}}/showtimes
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "showtime_type": "event",
    "room": {{roomId}},
    "special_event_id": {{eventId}},
    "projection_type": 1,
    "language": 1,
    "start_time": "2026-07-25T20:00:00Z",
    "end_time": "2026-07-25T22:00:00Z",
    "currency": 1,
    "price": 250,
    "earned_loyalty_points": 25
  }
}

vars:pre-request {
  cinemaId: 1
  roomId: 1
  eventId: 1
}

script:pre-request {
  const baseUrl = bru.getEnvVar('baseUrl') || 'http://127.0.0.1:4000/api/v1';
  bru.setVar('baseUrl', baseUrl);
}

script:post-response {
  const resBody = res.getBody();
  if (res.getStatus() === 201 && resBody?.data?.id) {
    bru.setEnvVar('showtimeId', resBody.data.id);
  }
}

docs {
  Nota: Para crear una función de película, cambia showtime_type a "movie" y usa movie en lugar de special_event_id.
}
