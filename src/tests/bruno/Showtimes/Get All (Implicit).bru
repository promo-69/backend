meta {
  name: Listar todas las funciones (admin)
  type: http
  seq: 20
}

get {
  url: {{baseUrl}}/showtimes/admin?startDate=2026-07-01&endDate=2026-09-30&movieId={{movieId}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

docs {
  Permite al administrador listar y filtrar todas las funciones del sistema.
  Filtros opcionales por Query Params: startDate, endDate, movieId, cinemaId.
}
