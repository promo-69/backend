meta {
  name: Get Showtime By ID
  type: http
  seq: 3
}

get {
  url: {{baseUrl}}/showtimes/{{testShowtimeId}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

vars:pre-request {
  testShowtimeId: 1
}

script:pre-request {
  const baseUrl = bru.getEnvVar('baseUrl') || 'https://127.0.0.1/api/v1';
  bru.setVar('baseUrl', baseUrl);
}
