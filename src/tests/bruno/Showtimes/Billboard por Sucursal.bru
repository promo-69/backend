meta {
  name: Cartelera por Sucursal (Pública)
  type: http
  seq: 11
}

get {
  url: {{baseUrl}}/cinemas/{{testCinemaId}}/showtimes/billboard
  body: none
  auth: none
}

vars:pre-request {
  testCinemaId: 1
}

docs {
  Endpoint público — no requiere token.
  Devuelve la cartelera filtrada por sucursal (cinemaId).
  Ideal para la pantalla "Elige tu cine" > "Ver cartelera".
}
