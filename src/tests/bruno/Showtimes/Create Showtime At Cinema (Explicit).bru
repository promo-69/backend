meta {
  name: Crear Funcion en Sucursal (Explicito)
  type: http
  seq: 15
}

post {
  url: {{baseUrl}}/cinemas/{{cinemaId}}/showtimes
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "room": {{roomId}},
    "movie": {{movieId}},
    "projection_type": 1,
    "language": 1,
    "start_time": "2026-09-01T20:00:00Z",
    "end_time": "2026-09-01T22:30:00Z",
    "currency": 1,
    "price": 10.00
  }
}
