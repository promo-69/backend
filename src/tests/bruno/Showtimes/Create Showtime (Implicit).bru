meta {
  name: Crear Funcion (Implicito)
  type: http
  seq: 14
}

post {
  url: {{baseUrl}}/showtimes
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "room": {{roomId}},
    "movie": {{movieId}},
    "projection_type": 1,
    "language": 1,
    "start_time": "2026-08-15T18:00:00Z",
    "end_time": "2026-08-15T20:30:00Z",
    "currency": 1,
    "price": 12.50,
    "earned_loyalty_points": 25
  }
}

script:post-response {
  const resBody = res.getBody();
  if (res.getStatus() === 201 && resBody?.data?.showtime_id) {
    bru.setEnvVar("showtimeId", resBody.data.showtime_id);
  }
}
