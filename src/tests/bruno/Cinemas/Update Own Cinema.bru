meta {
  name: Update Own Cinema
  type: http
  seq: 5
}

put {
  url: {{baseUrl}}/cinemas
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "phone": "+58212000000",
    "openingTime": "10:00",
    "closingTime": "22:00"
  }
}

script:pre-request {
  const baseUrl = bru.getEnvVar('baseUrl') || 'http://127.0.0.1:4000/api/v1';
  bru.setVar('baseUrl', baseUrl);
}
