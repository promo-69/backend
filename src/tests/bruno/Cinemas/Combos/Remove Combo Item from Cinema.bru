meta {
  name: Remove Combo Item from Cinema
  type: http
  seq: 15
}

delete {
  url: {{baseUrl}}/cinemas/:cinemaId/combos/:id/items/:itemId
  body: none
  auth: bearer
}

params:path {
  cinemaId: 1
  id: 1
  itemId: 1
}

auth:bearer {
  token: {{accessToken}}
}

script:pre-request {
  const baseUrl = bru.getEnvVar('baseUrl') || 'http://127.0.0.1:4000/api/v1';
  bru.setVar('baseUrl', baseUrl);
}
