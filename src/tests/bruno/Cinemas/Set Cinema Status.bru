meta {
  name: Set Cinema Status
  type: http
  seq: 6
}

patch {
  url: {{baseUrl}}/cinemas/{{testCinemaId}}/status
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "active": false
  }
}

script:pre-request {
  const baseUrl = bru.getEnvVar('baseUrl') || 'http://127.0.0.1:4000/api/v1';
  bru.setVar('baseUrl', baseUrl);
}
