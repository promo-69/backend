meta {
  name: Remove Employee from Cinema
  type: http
  seq: 10
}

delete {
  url: {{baseUrl}}/cinemas/{{testCinemaId}}/employees/{{testEmployeeId}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

script:pre-request {
  const baseUrl = bru.getEnvVar('baseUrl') || 'http://127.0.0.1:4000/api/v1';
  bru.setVar('baseUrl', baseUrl);
}
