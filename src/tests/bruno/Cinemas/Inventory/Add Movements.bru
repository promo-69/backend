meta {
  name: Add Movements to Inventory in Cinema
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/cinemas/{{testCinemaId}}/inventory/{{testInventoryId}}/movements
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  [
    { "operationType": 1, "quantity": 50, "remarks": "Restock from central warehouse", "unit_cost": 5.00 }
  ]
}

vars:pre-request {
  testCinemaId: 1
  testInventoryId: 1
}

script:pre-request {
  const baseUrl = bru.getEnvVar('baseUrl') || 'http://127.0.0.1:4000/api/v1';
  bru.setVar('baseUrl', baseUrl);
}
