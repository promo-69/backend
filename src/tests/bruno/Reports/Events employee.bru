meta {
  name: Events Report
  type: http
  seq: 3
}

get {
  url: {{baseUrl}}/reports/events
  body: none
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

params:query {
  from: {{fromDate}}
  to: {{toDate}}
}

docs {
  Reporte de eventos especiales: funciones, boletos vendidos, ingresos y ocupación.
  Permiso requerido: CRUD:READ:REPORTS-EVENTS
}
